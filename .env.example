# Project-local overrides. API keys and shared Neon credentials can live in
# a cross-project shared.env instead (see README). Values here override shared.env.

# Optional: explicit path to shared secrets (otherwise auto-detected at
# ~/.secrets/shared.env or ~/Downloads/shared.env)
# SHARED_ENV_PATH=/Users/you/Downloads/shared.env

# HANA API (Neon BrainForge) — usually provided by shared.env
HANA_BASE_URL=https://hana.neonaialpha.com
HANA_USERNAME=guest
HANA_PASSWORD=password
# BrainForge/Security (4090-x1-3): OpenAI-compatible API key for direct vLLM
HANA_KLATCHAT_PASSWORD=sk_klatchat2024
# Direct vLLM host (default matches demo 4090-x1-3; shared.env may use VLLM_BASE_URL)
# NEON_SECURITY_VLLM_BASE_URL=https://4090-x1-3.neonaiservices2.com/vllm0

# Neon vLLM direct access — usually provided by shared.env
VLLM_API_KEY=sk_n30nn30n

# Comparison providers — usually provided by shared.env.
# Leave these unset (or commented) unless you intentionally override.
# Do not copy your-*-api-key-here placeholders into .env — they override
# real keys from shared.env and the provider disappears from the picker.
# FIREWORKS_API_KEY=
# TOGETHER_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=

# Orchestrator LLM (used to monitor conversation endings)
ORCHESTRATOR_MODEL=gpt-4o-mini

# App
CORS_ORIGINS=http://localhost:3000
